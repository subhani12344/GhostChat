# Production Environment Configuration Template for GhostChat Server

# Running Environment (production / development)
NODE_ENV=production

# Server Port
PORT=4000

# PostgreSQL Connection String (If empty, falls back to backend/database.json file database)
DATABASE_URL=postgresql://user:password@localhost:5432/ghostchat

# JWT Cryptographic Signing Secret (MUST be at least 32 characters in production)
JWT_SECRET=generate_a_long_cryptographically_secure_random_string_here

# Allowed Origins (CORS & Socket.io) - comma-separated list of front-end domains
ALLOWED_ORIGINS=http://localhost:3000,https://ghostchat-app.vercel.app,https://yourdomain.com

# SMTP Verification Settings (Nodemailer config)
# Use SMTP_SERVICE (e.g., Gmail) OR specify SMTP_HOST & SMTP_PORT
# SMTP_SERVICE=Gmail
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=postmaster@yourdomain.com
SMTP_PASS=your_smtp_password

# -------------------------------------------------------------
# Transactional Email APIs Integration Configuration
# (If configured, these take priority over standard SMTP above)
# -------------------------------------------------------------
# 1. Resend API
RESEND_API_KEY=re_123456789...

# 2. Postmark API
POSTMARK_SERVER_TOKEN=your_postmark_server_token...

# 3. Mailgun API
MAILGUN_API_KEY=your_mailgun_api_key...
MAILGUN_DOMAIN=mg.yourdomain.com

# 4. Optional Custom Sender Email Address
EMAIL_FROM=GhostChat <no-reply@yourdomain.com>

# Telemetry and Security Tuning
API_RATE_LIMIT=300
AUTH_RATE_LIMIT=30
JSON_BODY_LIMIT=1mb
